# Bu dosyayı .env.production olarak kopyala.
# Gerçek değerleri sadece VPS üzerinde .env.production içine yaz.
# .env.production dosyasını GitHub'a gönderme.

PUBLIC_HOST=video.senindomain.com
WEBUI_PORT=8501
API_PORT=8080

# API CORS güvenliği.
# Tek domain kullanacaksan:
CORS_ALLOWED_ORIGINS=https://video.senindomain.com

# İleride API'yi ayrı subdomain ile açarsan:
# CORS_ALLOWED_ORIGINS=https://video.senindomain.com,https://api-video.senindomain.com

# Redis container adı. Değiştirme.
REDIS_HOST=redis

# İsteğe bağlı proxy
# HTTP_PROXY=
# HTTPS_PROXY=
