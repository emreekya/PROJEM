# /etc/nginx/sites-available/moneyprinterturbo-webui
# Domain: video.senindomain.com
#
# Kurulumdan sonra:
#   sudo ln -s /etc/nginx/sites-available/moneyprinterturbo-webui /etc/nginx/sites-enabled/
#   sudo nginx -t
#   sudo systemctl reload nginx
#   sudo certbot --nginx -d video.senindomain.com

server {
    listen 80;
    server_name video.senindomain.com;

    client_max_body_size 2048M;

    # Streamlit WebSocket desteği
    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }
}
