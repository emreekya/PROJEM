# /etc/nginx/sites-available/moneyprinterturbo-api
# Domain: api-video.senindomain.com
#
# API'yi herkese açık vermek istemiyorsan bu dosyayı kullanma.
# Önce WebUI'yi ayağa kaldır, API'yi daha sonra aç.

server {
    listen 80;
    server_name api-video.senindomain.com;

    client_max_body_size 2048M;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }
}
